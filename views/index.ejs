<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Jhan Presentes</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="top-bar">
    <div class="logo">
      <img src="/images/logo.jpeg" alt="Logo Jhan Presentes">
    </div>

    <form action="/" method="GET" class="search-bar">
      <input type="text" name="busca" placeholder="Buscar produtos...">
      <button type="submit">🔍</button>
    </form>

    <a href="/login" class="login-link">Login</a>
  </header>

  <nav class="categoria-bar">
    <span>Categorias:</span>
    <a href="/produtos?categoria=masculinos">Brinquedos Masculinos</a>
    <a href="/produtos?categoria=femininos">Brinquedos Femininos</a>
  </nav>

  <main class="conteudo-principal">
    <h2>Bem-vindo à nossa loja!</h2>
    <p>Escolha uma categoria acima para começar.</p>
  </main>
</body>
</html>